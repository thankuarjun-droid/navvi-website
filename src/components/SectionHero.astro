---
const {
  eyebrow,
  title,
  lead,
  primaryLabel = 'WhatsApp Navvi',
  primaryHref = 'https://wa.me/919894466715',
  image,
  imageAlt = ''
} = Astro.props;
---
<section class="page-hero-block">
  <div class="page-hero-copy visual-band">
    <div class="container page-hero-entrance">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{lead}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>
        <slot />
      </div>
    </div>
  </div>
  {image && (
    <div class="hero-banner" data-reveal>
      <div class="container">
        <div class="hero-banner-frame media-frame">
          <img src={image} alt={imageAlt} loading="eager" width="1180" height="520" />
        </div>
      </div>
    </div>
  )}
</section>