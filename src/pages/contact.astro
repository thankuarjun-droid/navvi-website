---
import Layout from '../components/Layout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<Layout title="Contact Navvi | Book Factory Assessment, SewCoach or SewTrak Demo">
  <main>
    <SectionHero eyebrow="Book a discussion" title="Tell us what your factory needs." lead="Use WhatsApp for the fastest response. The form also opens WhatsApp with your details, so nothing gets lost." primaryLabel="Open WhatsApp" primaryHref="https://wa.me/919894466715?text=Hello%20Navvi%2C%20I%20want%20to%20book%20a%20discussion." image="/assets/hero/hero-blog.jpg" imageAlt="Discuss your factory needs with Navvi" />
    <section class="section"><div class="container contact-grid"><aside class="card card-featured"><span class="kicker">Direct contact</span><h3>Navvi Corporations</h3><p><strong>Phone / WhatsApp:</strong><br /><a href="tel:+919894466715">+91 98944 66715</a></p><p><strong>Email:</strong><br /><a href="mailto:navvocorp@gmail.com">navvocorp@gmail.com</a></p><p><strong>Booking:</strong><br />Google Calendar booking link can be added inside <code>public/script.js</code>.</p><div class="section-actions"><a class="btn btn-primary" href="https://wa.me/919894466715?text=Hello%20Navvi%2C%20I%20want%20to%20book%20a%20discussion.">Open WhatsApp</a><a class="btn btn-outline" data-booking-link href="#">Book online</a></div></aside><section class="card"><span class="kicker">Lead form</span><h3>Send details through WhatsApp</h3><form class="contact-form" data-lead-form><div class="field"><label for="name">Your name</label><input id="name" name="name" required placeholder="Your name" /></div><div class="field"><label for="company">Company / factory</label><input id="company" name="company" required placeholder="Factory name" /></div><div class="field"><label for="interest">What do you want?</label><select id="interest" name="interest"><option>Free Factory Assessment</option><option>SewCoach Training School Setup</option><option>SewTrak Demo</option><option>Case Result Discussion</option></select></div><div class="field"><label for="message">Message</label><textarea id="message" name="message" placeholder="Tell us your main problem."></textarea></div><button class="btn btn-secondary" type="submit">Send by WhatsApp</button></form></section></div></section>
  </main>
</Layout>
