---
import Layout from '../components/Layout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<Layout title="SewCoach | Sewing Operator Training School Setup">
  <main>
    <SectionHero eyebrow="SewCoach by Navvi" title="Make new sewing operators line-ready in 8 days." lead="Set up a scientific training room with certified trainers, ready-made courses, app-based tracking, OJT and certification." primaryLabel="WhatsApp SEWCOACH" primaryHref="https://wa.me/919894466715?text=SEWCOACH" image="/assets/hero/hero-sewcoach.jpg" imageAlt="SewCoach sewing operator training room">
      <a class="btn btn-outline" href="#programs">View programs</a>
    </SectionHero>
    <section class="section"><div class="container split"><div><p class="eyebrow">Training school setup</p><h2>Without 30-day training delays.</h2><p class="muted">SewCoach is built for garment factories that need a repeatable way to hire, train and measure new sewing operators.</p><div class="proof-bar"><div class="proof-item"><strong>10+</strong><span>Factories served</span></div><div class="proof-item"><strong>18%</strong><span>Average efficiency gain</span></div><div class="proof-item"><strong>1,800+</strong><span>Operators trained</span></div><div class="proof-item"><strong>40%+</strong><span>Efficiency by Day 8 target</span></div></div></div><div class="media-frame"><img src="/assets/sewcoach/sewcoach-flyer.png" alt="SewCoach flyer showing training programs and app features" /></div></div></section>
    <section class="section section-blue"><div class="container grid-2"><article class="card"><span class="kicker">Old way</span><h3>Training depends on people and paper.</h3><ul class="list"><li>30+ day training delay.</li><li>Paper tracking and weak visibility.</li><li>Trainer-dependent results.</li><li>Low operator efficiency at line entry.</li></ul></article><article class="card card-featured"><span class="kicker">SewCoach way</span><h3>Every trainee, cycle and skill is measured.</h3><ul class="list"><li>8-day structured training.</li><li>LMS courses ready to use.</li><li>OJT and training tracker.</li><li>Performance improvement and multi-skill certification.</li></ul></article></div></section>
    <section class="section" id="programs"><div class="container"><div class="section-head"><p class="eyebrow">Two programs</p><h2>Built for garment factories.</h2></div><div class="grid-2"><article class="card card-featured"><span class="kicker">15 days</span><h3>ToT - Training of Trainers</h3><p class="muted">Build your own certified factory trainers so the system continues without Navvi being present every day.</p></article><article class="card card-featured"><span class="kicker">8 + 8 days</span><h3>GPOT - Great Performance Operator Training</h3><p class="muted">Make fresh hires line-ready faster with structured training, OJT and app-based tracking.</p></article></div></div></section>
  </main>
</Layout>
