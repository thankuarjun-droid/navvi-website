---
import Layout from '../components/Layout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<Layout title="Anonymous Factory Results | Navvi Corporations">
  <main>
    <SectionHero eyebrow="Results without public client names" title="Anonymous factory results. Client names shared in person where permitted." lead="Many garment factories hesitate to publish operational data. We respect that. The results below are framed anonymously for public viewing." primaryLabel="Discuss results" primaryHref="https://wa.me/919894466715?text=Hello%20Navvi%2C%20I%20want%20to%20discuss%20your%20anonymous%20factory%20results." image="/assets/hero/hero-factory.jpg" imageAlt="Factory performance improvement results" />
    <section class="section"><div class="container grid-3"><article class="card card-featured"><span class="kicker">12-line knitwear exporter</span><h3>Throughput and delivery improvement</h3><p class="muted">The factory needed better production rhythm, stronger supervisor control and faster order movement.</p><div class="case-stat"><div><strong>+25%</strong><span>Throughput</span></div><div><strong>₹3.2 Cr</strong><span>Yearly savings</span></div><div><strong>90 days</strong><span>Initial turnaround</span></div></div></article><article class="card card-featured"><span class="kicker">Export unit</span><h3>Hiring, engagement and OTIF control</h3><p class="muted">The factory had bad hires, low engagement and inconsistent delivery performance.</p><div class="case-stat"><div><strong>95%</strong><span>OTIF</span></div><div><strong>₹3.8 Cr</strong><span>Savings</span></div><div><strong>-60%</strong><span>Bad hires</span></div></div></article><article class="card card-featured"><span class="kicker">Garment plant</span><h3>Operational loss reduction</h3><p class="muted">The factory was losing margin through process gaps, waste and poor visibility.</p><div class="case-stat"><div><strong>-85%</strong><span>Loss reduction</span></div><div><strong>400-500%</strong><span>ROI</span></div><div><strong>₹1.5 Cr</strong><span>Annual savings</span></div></div></article></div></section>
  </main>
</Layout>
